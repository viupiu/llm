{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "dos-coder-gemma": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DOS Coder · Gemma-4-31B",
      "options": {
        "baseURL": "http://dos-coder.nano.internal/gemma/v1",
      },
      "models": {
        "gemma": {
          "name": "Gemma-4-31B (agent)",
          "limit": {
            "context": 49152,
            "output": 8192
          }
        }
      }
    },
    "dos-coder-qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DOS Coder · Qwen3.6-27B",
      "options": {
        "baseURL": "http://dos-coder.nano.internal/qwen/v1",
      },
      "models": {
        "qwen": {
          "name": "Qwen3.6-27B (background / longContext)",
          "limit": {
            "context": 98304,
            "output": 12288
          }
        }
      }
    }
  },
  "model": "dos-coder-gemma/gemma",
  "small_model": "dos-coder-qwen/qwen"
}
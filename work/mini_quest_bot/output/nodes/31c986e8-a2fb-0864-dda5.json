        "key": "rcxjw",
        "data": {},
        "text": ":lu: [if(%has_key)]{Вы вставляете предмет в замочное отверстие. Щёлк — и дверь распахивается. За ней — ночной воздух и звёзды. [@goto(\"Свобода\")]} [elsif(%has_staff)]{Вы подходите к двери с артефактом. Механизм откликается, двери отворяются. Впереди — свобода. [@goto(\"Свобода\")]} [else]{У вас нет предмета, который мог бы открыть эту дверь.}",

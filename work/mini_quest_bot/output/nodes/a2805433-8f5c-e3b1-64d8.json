        "data": {},
        "text": "Направо пошёл",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "rhd4w",
        "data": {},
        "text": "Правый коридор выглядит более живым, пойду туда",

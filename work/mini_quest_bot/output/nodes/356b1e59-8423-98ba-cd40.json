        "inlineStyleRanges": []
      },
      {
        "key": "ywz3w",
        "data": {},
        "text": "На право!",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "9kk6c",
        "data": {},
        "text": "Направо пошёл",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "02nai",
        "data": {},
        "text": "Правый коридор выглядит более живым, пойду туда",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "t0m6l",
        "data": {},
        "text": "Справа куда-то журчит, пойдём",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "y1krl",
        "data": {},
        "text": "Коридор справа, поехали туда",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "xp2rm",
        "data": {},
        "text": "Там, откуда вода шумит",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "r8f3b",
        "data": {},
        "text": "В ту сторону, откуда слышен рев воды",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "nmn1y",
        "data": {},
        "text": "Слышу шум воды, пойдём к нему",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "dcnhx",
        "data": {},
        "text": "Воду слышу, значит, направо",
        "type": "unstyled",
        "depth": 0,

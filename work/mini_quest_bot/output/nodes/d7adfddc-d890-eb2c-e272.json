      },
      {
        "key": "d133c",
        "data": {},
        "text": "Направо пошёл",
        "type": "unstyled",
        "depth": 0,
        "entityRanges": [],
        "inlineStyleRanges": []
      },
      {
        "key": "mn2jo",
        "data": {},
        "text": "Правый коридор выглядит более живым, пойду туда",
        "type": "unstyled",
